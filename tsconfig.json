{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "__tests__",
    "backend",
    ".expo",
    "dist",
    "coverage",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ]
}
